<%- include('../partials/header') %>

<!-- Filter — sembunyikan untuk karyawan -->
<% if (user.role !== 'karyawan') { %>
<div class="card card-outline card-secondary mb-3">
  <div class="card-body py-2">
    <form method="GET" action="/penggajian">
      <div class="row">
        <div class="col-6 col-md-3 mb-2">
          <select name="bulan" class="form-control form-control-sm">
            <% ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'].forEach((b,i) => { %>
              <option value="<%= i+1 %>" <%= filter.bulan==i+1?'selected':'' %>><%= b %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-6 col-md-2 mb-2">
          <input type="number" name="tahun" class="form-control form-control-sm" value="<%= filter.tahun || new Date().getFullYear() %>">
        </div>
        <div class="col-12 col-md-4 mb-2">
          <select name="karyawan_id" class="form-control form-control-sm">
            <option value="">Semua Karyawan</option>
            <% karyawan.forEach(k => { %>
              <option value="<%= k.id %>" <%= filter.karyawan_id==k.id?'selected':'' %>><%= k.nama %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-12 col-md-3 mb-2 d-flex" style="gap:6px">
          <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-filter"></i> Filter</button>
          <a href="/penggajian" class="btn btn-sm btn-secondary">Reset</a>
        </div>
      </div>
    </form>
  </div>
</div>
<% } %>

<div class="card card-outline card-primary">
  <div class="card-header d-flex align-items-center justify-content-between">
    <h3 class="card-title mb-0">
      <i class="fas fa-money-bill-wave mr-1"></i>
      <% if (user.role === 'karyawan') { %>Riwayat Penggajian Saya<% } else { %>Data Penggajian<% } %>
      <span class="badge badge-success ml-1" style="font-size:11px">Rp <%= Number(totalGaji).toLocaleString('id-ID') %></span>
    </h3>
    <% if (user.role !== 'owner') { %>
    <a href="/penggajian/create" class="btn btn-primary btn-sm">
      <i class="fas fa-plus"></i> <span class="d-none d-sm-inline">Input</span>
    </a>
    <% } %>
  </div>
  <div class="card-body p-0">

    <!-- Mobile -->
    <div class="d-md-none p-2">
      <% penggajian.forEach(p => { %>
      <div class="card mb-2" style="border-left:4px solid <%= p.status==='pending'?'#ffc107':p.proses==='Packing'?'#28a745':'#6c757d' %>">
        <div class="card-body p-3">
          <div class="d-flex justify-content-between align-items-start">
            <div style="flex:1">
              <div class="d-flex align-items-center justify-content-between">
                <strong><%= p.nama_karyawan %></strong>
                <div>
                  <span class="badge badge-<%= p.proses==='Packing'?'success':p.proses==='QC'?'info':'secondary' %>"><%= p.proses %></span>
                  <% if (p.status === 'pending') { %>
                  <span class="badge badge-warning ml-1">Pending</span>
                  <% } %>
                </div>
              </div>
              <div style="font-size:12px;color:#6c757d">
                <i class="fas fa-tshirt mr-1"></i><%= p.nama_produk %> ·
                <%= new Date(p.tanggal).toLocaleDateString('id-ID',{day:'2-digit',month:'2-digit',year:'2-digit'}) %>
              </div>
              <div class="d-flex justify-content-between mt-1">
                <small><%= p.jumlah %> pcs × Rp <%= Number(p.upah_per_pcs).toLocaleString('id-ID') %></small>
                <strong class="text-success">Rp <%= Number(p.total_gaji).toLocaleString('id-ID') %></strong>
              </div>
            </div>
            <div class="ml-2 d-flex flex-column" style="gap:3px">
              <% if (p.status === 'pending' && user.role === 'admin') { %>
              <form action="/penggajian/<%= p.id %>/approve" method="POST">
                <button type="submit" class="btn btn-success btn-xs" title="Setujui">
                  <i class="fas fa-check"></i>
                </button>
              </form>
              <% } %>
              <% if (user.role !== 'owner' && (user.role === 'admin' || (user.role === 'karyawan' && p.status === 'pending'))) { %>
              <form action="/penggajian/<%= p.id %>?_method=DELETE" method="POST"
                    onsubmit="return confirm('Hapus data ini?')">
                <button type="submit" class="btn btn-danger btn-xs"><i class="fas fa-trash"></i></button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
      <% if (!penggajian.length) { %>
        <div class="text-center text-muted py-3"><i class="fas fa-inbox mr-2"></i>Tidak ada data</div>
      <% } %>
    </div>

    <!-- Desktop -->
    <div class="d-none d-md-block">
      <table id="tabelGaji" class="table table-bordered table-hover table-sm mb-0">
        <thead class="thead-dark">
          <tr>
            <th>Tanggal</th>
            <th>Karyawan</th>
            <th>Produk</th>
            <th>Proses</th>
            <th>Status</th>
            <th>Jumlah</th>
            <th>Upah/pcs</th>
            <th>Total Gaji</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% penggajian.forEach(p => { %>
          <tr class="<%= p.status==='pending'?'table-warning':'' %>">
            <td style="white-space:nowrap"><%= new Date(p.tanggal).toLocaleDateString('id-ID') %></td>
            <td><strong><%= p.nama_karyawan %></strong></td>
            <td><%= p.nama_produk %></td>
            <td>
              <span class="badge badge-<%= p.proses==='Packing'?'success':p.proses==='QC'?'info':'secondary' %>">
                <%= p.proses %>
              </span>
            </td>
            <td>
              <span class="badge badge-<%= p.status==='pending'?'warning':'success' %>">
                <%= p.status === 'pending' ? 'Menunggu' : 'Disetujui' %>
              </span>
            </td>
            <td><%= p.jumlah %> pcs</td>
            <td>Rp <%= Number(p.upah_per_pcs).toLocaleString('id-ID') %></td>
            <td class="font-weight-bold text-success">Rp <%= Number(p.total_gaji).toLocaleString('id-ID') %></td>
            <td>
              <% if (p.status === 'pending' && user.role === 'admin') { %>
              <form action="/penggajian/<%= p.id %>/approve" method="POST" class="d-inline">
                <button type="submit" class="btn btn-success btn-xs" title="Setujui">
                  <i class="fas fa-check"></i> Setujui
                </button>
              </form>
              <% } %>
              <% if (user.role !== 'owner' && (user.role === 'admin' || (user.role === 'karyawan' && p.status === 'pending'))) { %>
              <form action="/penggajian/<%= p.id %>?_method=DELETE" method="POST" class="d-inline"
                    onsubmit="return confirm('Hapus data ini?')">
                <button type="submit" class="btn btn-danger btn-xs"><i class="fas fa-trash"></i></button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
          <% if (!penggajian.length) { %>
          <tr><td colspan="9" class="text-center text-muted py-3">Tidak ada data</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>$(document).ready(function(){ $('#tabelGaji').DataTable({ order:[[0,'desc']], pageLength:25 }); });</script>
<%- include('../partials/footer') %>
