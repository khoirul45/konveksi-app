<%- include('../partials/header') %>

<div class="card card-outline card-success">
  <div class="card-header d-flex align-items-center justify-content-between">
    <h3 class="card-title mb-0"><i class="fas fa-tshirt mr-1"></i>Master Produk</h3>
    <% if (user.role === 'admin') { %>
    <a href="/produk/create" class="btn btn-success btn-sm">
      <i class="fas fa-plus"></i> <span class="d-none d-sm-inline">Tambah Produk</span>
    </a>
    <% } %>
  </div>
  <div class="card-body p-0">

    <!-- MOBILE -->
    <div class="d-md-none p-2">
      <% produk.forEach((p, i) => { %>
      <div class="card mb-2" style="border-left:4px solid #28a745">
        <div class="card-body p-3">
          <div class="d-flex align-items-center justify-content-between">
            <div style="flex:1;min-width:0">
              <div class="font-weight-bold">
                <i class="fas fa-tshirt mr-1 text-success"></i><%= p.nama_produk %>
              </div>
              <div class="text-muted" style="font-size:12px;margin-top:2px"><%= p.deskripsi || '-' %></div>
              <div class="font-weight-bold text-success mt-1">Rp <%= Number(p.harga_jual).toLocaleString('id-ID') %></div>
            </div>
            <div class="d-flex flex-column ml-2" style="gap:4px">
              <a href="/produk/<%= p.id %>/detail" class="btn btn-info btn-sm mb-1">
                <i class="fas fa-eye"></i> Detail
              </a>
              <% if (user.role === 'admin') { %>
              <a href="/produk/<%= p.id %>/edit" class="btn btn-warning btn-sm mb-1">
                <i class="fas fa-edit"></i>
              </a>
              <form action="/produk/<%= p.id %>?_method=DELETE" method="POST"
                    onsubmit="return confirm('Hapus <%= p.nama_produk %>?')">
                <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
      <% if (!produk.length) { %>
        <div class="text-center text-muted py-3">Belum ada produk</div>
      <% } %>
    </div>

    <!-- DESKTOP -->
    <div class="d-none d-md-block">
      <table id="tabelProduk" class="table table-bordered table-hover table-striped mb-0">
        <thead class="thead-dark">
          <tr>
            <th>#</th>
            <th>Nama Produk</th>
            <th>Deskripsi</th>
            <th>Harga Jual</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% produk.forEach((p, i) => { %>
          <tr>
            <td><%= i+1 %></td>
            <td><i class="fas fa-tshirt mr-1 text-success"></i><strong><%= p.nama_produk %></strong></td>
            <td class="text-muted"><%= p.deskripsi || '-' %></td>
            <td>Rp <%= Number(p.harga_jual).toLocaleString('id-ID') %></td>
            <td>
              <a href="/produk/<%= p.id %>/detail" class="btn btn-info btn-xs">
                <i class="fas fa-eye"></i> Detail
              </a>
              <% if (user.role === 'admin') { %>
              <a href="/produk/<%= p.id %>/edit" class="btn btn-warning btn-xs">
                <i class="fas fa-edit"></i>
              </a>
              <form action="/produk/<%= p.id %>?_method=DELETE" method="POST" class="d-inline"
                    onsubmit="return confirm('Hapus produk <%= p.nama_produk %>?')">
                <button type="submit" class="btn btn-danger btn-xs"><i class="fas fa-trash"></i></button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </div>
</div>

<script>$(document).ready(function(){ $('#tabelProduk').DataTable(); });</script>
<%- include('../partials/footer') %>
