<%- include('../partials/header') %>
<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card card-success card-outline">
      <div class="card-header"><h3 class="card-title"><i class="fas fa-plus-circle mr-2"></i>Tambah Produk</h3></div>
      <form action="/produk" method="POST">
        <div class="card-body">
          <div class="form-group">
            <label>Nama Produk <span class="text-danger">*</span></label>
            <input type="text" name="nama_produk" class="form-control" placeholder="Contoh: Kaos Polos" required>
          </div>
          <div class="form-group">
            <label>Deskripsi</label>
            <textarea name="deskripsi" class="form-control" rows="2" placeholder="Deskripsi produk (opsional)"></textarea>
          </div>
          <div class="form-group">
            <label>Harga Jual (Rp)</label>
            <div class="input-group">
              <div class="input-group-prepend"><span class="input-group-text">Rp</span></div>
              <input type="number" name="harga_jual" class="form-control" placeholder="50000" min="0">
            </div>
          </div>
        </div>
        <div class="card-footer">
          <button type="submit" class="btn btn-success"><i class="fas fa-save mr-1"></i>Simpan</button>
          <a href="/produk" class="btn btn-secondary ml-2"><i class="fas fa-arrow-left mr-1"></i>Kembali</a>
        </div>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
