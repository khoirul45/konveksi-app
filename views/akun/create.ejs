<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card card-primary card-outline">
      <div class="card-header">
        <h3 class="card-title"><i class="fas fa-user-plus mr-2"></i>Tambah Akun</h3>
      </div>
      <form action="/akun" method="POST">
        <div class="card-body">
          <div class="form-group">
            <label>Username <span class="text-danger">*</span></label>
            <input type="text" name="username" class="form-control" placeholder="Masukkan username" required>
            <small class="text-muted">Gunakan huruf kecil, tanpa spasi. Contoh: budi_santoso</small>
          </div>
          <div class="form-group">
            <label>Password <span class="text-danger">*</span></label>
            <input type="password" name="password" class="form-control" placeholder="Min. 6 karakter" required minlength="6">
          </div>
          <div class="form-group">
            <label>Role <span class="text-danger">*</span></label>
            <select name="role" class="form-control" id="selectRole" onchange="toggleKaryawan(this.value)" required>
              <option value="">-- Pilih Role --</option>
              <option value="karyawan">Karyawan</option>
              <option value="owner">Owner</option>
              <option value="admin">Admin</option>
            </select>
          </div>
          <div class="form-group" id="groupKaryawan" style="display:none">
            <label>Pilih Karyawan <span class="text-danger">*</span></label>
            <select name="karyawan_id" class="form-control" id="selectKaryawan">
              <option value="">-- Pilih Karyawan --</option>
              <% karyawan.forEach(k => { %>
                <option value="<%= k.id %>"><%= k.nama %> (<%= k.jabatan %>)</option>
              <% }) %>
            </select>
            <small class="text-muted">Hanya karyawan aktif yang belum punya akun yang tampil</small>
          </div>

          <div class="alert alert-info">
            <i class="fas fa-info-circle mr-2"></i>
            <strong>Info Role:</strong><br>
            <span class="badge badge-warning">Karyawan</span> — Bisa input penggajian sendiri, lihat riwayat gaji sendiri<br>
            <span class="badge badge-success">Owner</span> — Hanya bisa melihat semua data (read only)<br>
            <span class="badge badge-primary">Admin</span> — Akses penuh ke semua fitur
          </div>
        </div>
        <div class="card-footer">
          <button type="submit" class="btn btn-primary"><i class="fas fa-save mr-1"></i>Simpan</button>
          <a href="/akun" class="btn btn-secondary ml-2"><i class="fas fa-arrow-left mr-1"></i>Kembali</a>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function toggleKaryawan(role) {
  const group = document.getElementById('groupKaryawan');
  const select = document.getElementById('selectKaryawan');
  if (role === 'karyawan') {
    group.style.display = 'block';
    select.required = true;
  } else {
    group.style.display = 'none';
    select.required = false;
  }
}
</script>

<%- include('../partials/footer') %>
