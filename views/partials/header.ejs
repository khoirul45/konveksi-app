<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Konveksi App</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/admin-lte/3.2.0/css/adminlte.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.21/css/dataTables.bootstrap4.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#3c8dbc">
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#1a2232">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="Konveksi App">
  <link rel="apple-touch-icon" href="/icons/icon-152x152.png">
  <script>
    (function() {
      const theme = localStorage.getItem('theme') || 'auto';
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const isDark = theme === 'dark' || (theme === 'auto' && prefersDark);
      document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
    })();
  </script>
</head>
<body class="hold-transition sidebar-mini layout-fixed">
<div class="wrapper">

  <nav class="main-header navbar navbar-expand navbar-white navbar-light" role="navigation">
    <ul class="navbar-nav" role="list">
      <li class="nav-item" role="listitem">
        <a class="nav-link" data-widget="pushmenu" href="#" role="button" aria-label="Toggle sidebar">
          <i class="fas fa-bars" aria-hidden="true"></i>
        </a>
      </li>
    </ul>
    <ul class="navbar-nav ml-auto" role="list">
      <!-- Notifikasi (hanya admin & owner) -->
      <% if (user && (user.role === 'admin' || user.role === 'owner')) { %>
      <li class="nav-item dropdown" role="listitem">
        <a class="nav-link" data-toggle="dropdown" href="#" id="notifBell" aria-label="Notifikasi">
          <i class="fas fa-bell" aria-hidden="true"></i>
          <span class="badge badge-danger navbar-badge" id="notifCount" style="display:none">0</span>
        </a>
        <div class="dropdown-menu dropdown-menu-right" style="width:320px;max-height:400px;overflow-y:auto" id="notifDropdown">
          <div class="dropdown-item d-flex justify-content-between align-items-center">
            <span class="font-weight-bold">Notifikasi</span>
            <a href="#" onclick="tandaiDibaca()" class="small text-primary">Tandai dibaca</a>
          </div>
          <div class="dropdown-divider"></div>
          <div id="notifList">
            <div class="dropdown-item text-muted text-center">Memuat...</div>
          </div>
        </div>
      </li>
      <% } %>

      <!-- Dark Mode -->
      <li class="nav-item" role="listitem">
        <a class="nav-link" href="#" id="navbar-theme-btn" onclick="toggleTheme(event)" aria-label="Ganti tema">
          <i class="fas fa-moon" id="theme-icon" aria-hidden="true"></i>
        </a>
      </li>

      <!-- User menu -->
      <li class="nav-item dropdown" role="listitem">
        <a class="nav-link" data-toggle="dropdown" href="#" aria-haspopup="true" aria-expanded="false">
          <i class="fas fa-user-circle mr-1" aria-hidden="true"></i><%= user ? user.username : '' %>
          <span class="badge badge-<%= user && user.role==='admin'?'primary':user && user.role==='owner'?'success':'warning' %> ml-1">
            <%= user ? user.role : '' %>
          </span>
        </a>
        <div class="dropdown-menu dropdown-menu-right">
          <a href="/logout" class="dropdown-item text-danger">
            <i class="fas fa-sign-out-alt mr-2" aria-hidden="true"></i>Logout
          </a>
        </div>
      </li>
    </ul>
  </nav>

  <aside class="main-sidebar sidebar-dark-primary elevation-4" aria-label="Sidebar navigasi">
    <a href="/dashboard" class="brand-link">
      <i class="fas fa-tshirt brand-image ml-3" style="color:#fff;font-size:1.5rem" aria-hidden="true"></i>
      <span class="brand-text font-weight-bold ml-2">Konveksi App</span>
    </a>
    <div class="sidebar">
      <div class="user-panel mt-3 pb-3 mb-3 d-flex">
        <div class="image">
          <i class="fas fa-user-circle" style="font-size:2rem;color:#adb5bd;margin-left:8px" aria-hidden="true"></i>
        </div>
        <div class="info">
          <a href="#" class="d-block"><%= user ? user.username : '' %></a>
          <small style="color:#adb5bd"><%= user ? user.role : '' %></small>
        </div>
      </div>
      <nav class="mt-2" aria-label="Menu sidebar">
        <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="list">

          <li class="nav-item" role="listitem">
            <a href="/dashboard" class="nav-link <%= title==='Dashboard'?'active':'' %>">
              <i class="nav-icon fas fa-tachometer-alt" aria-hidden="true"></i>
              <p>Dashboard</p>
            </a>
          </li>

          <!-- Menu untuk Admin & Owner -->
          <% if (user && (user.role === 'admin' || user.role === 'owner')) { %>
          <li role="listitem"><div class="nav-header">MASTER DATA</div></li>
          <li class="nav-item" role="listitem">
            <a href="/karyawan" class="nav-link <%= title.includes('Karyawan')?'active':'' %>">
              <i class="nav-icon fas fa-users" aria-hidden="true"></i>
              <p>Data Karyawan</p>
            </a>
          </li>
          <li class="nav-item" role="listitem">
            <a href="/produk" class="nav-link <%= title.includes('Produk')?'active':'' %>">
              <i class="nav-icon fas fa-tshirt" aria-hidden="true"></i>
              <p>Master Produk</p>
            </a>
          </li>
          <% } %>

          <li role="listitem"><div class="nav-header">OPERASIONAL</div></li>
          <li class="nav-item" role="listitem">
            <a href="/penggajian" class="nav-link <%= title.includes('Penggajian')?'active':'' %>">
              <i class="nav-icon fas fa-money-bill-wave" aria-hidden="true"></i>
              <p>Penggajian & Produksi</p>
            </a>
          </li>

          <% if (user && (user.role === 'admin' || user.role === 'owner')) { %>
          <li class="nav-item" role="listitem">
            <a href="/inventaris" class="nav-link <%= title.includes('Inventaris')?'active':'' %>">
              <i class="nav-icon fas fa-boxes" aria-hidden="true"></i>
              <p>Inventaris Produk Jadi</p>
            </a>
          </li>
          <li role="listitem"><div class="nav-header">LAPORAN</div></li>
          <li class="nav-item" role="listitem">
            <a href="/laporan" class="nav-link <%= title.includes('Laporan')?'active':'' %>">
              <i class="nav-icon fas fa-chart-bar" aria-hidden="true"></i>
              <p>Laporan & Grafik</p>
            </a>
          </li>
          <% } %>

          <!-- Menu khusus Admin -->
          <% if (user && user.role === 'admin') { %>
          <li role="listitem"><div class="nav-header">PENGATURAN</div></li>
          <li class="nav-item" role="listitem">
            <a href="/akun" class="nav-link <%= title.includes('Akun')?'active':'' %>">
              <i class="nav-icon fas fa-user-cog" aria-hidden="true"></i>
              <p>Manajemen Akun</p>
            </a>
          </li>
          <% } %>

        </ul>
      </nav>
    </div>
  </aside>

  <div class="content-wrapper">
    <div class="content-header">
      <div class="container-fluid">
        <div class="row mb-2">
          <div class="col-sm-6">
            <h1 class="m-0"><%= title %></h1>
          </div>
        </div>
      </div>
    </div>
    <div class="content">
      <div class="container-fluid">
        <% if (success && success.length > 0) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2" aria-hidden="true"></i><%= success %>
            <button type="button" class="close" data-dismiss="alert" aria-label="Tutup"><span>&times;</span></button>
          </div>
        <% } %>
        <% if (error && error.length > 0) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2" aria-hidden="true"></i><%= error %>
            <button type="button" class="close" data-dismiss="alert" aria-label="Tutup"><span>&times;</span></button>
          </div>
        <% } %>
