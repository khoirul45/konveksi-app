<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Konveksi App</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/admin-lte/3.2.0/css/adminlte.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.21/css/dataTables.bootstrap4.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <!-- PWA -->
  <link rel="manifest" href="/manifest.json">
  <!-- Fix: theme-color untuk Chrome & Safari, media query untuk Firefox -->
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#3c8dbc">
  <meta name="theme-color" media="(prefers-color-scheme: dark)"  content="#1a2232">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="Konveksi App">
  <link rel="apple-touch-icon" href="/icons/icon-152x152.png">
  <!-- Dark mode init (sebelum render agar tidak flicker) -->
  <script>
    (function() {
      const theme = localStorage.getItem('theme') || 'auto';
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const isDark = theme === 'dark' || (theme === 'auto' && prefersDark);
      if (isDark) document.documentElement.setAttribute('data-theme', 'dark');
      else document.documentElement.setAttribute('data-theme', 'light');
    })();
  </script>
</head>
<body class="hold-transition sidebar-mini layout-fixed">
<div class="wrapper">

  <!-- Navbar -->
  <nav class="main-header navbar navbar-expand navbar-white navbar-light" role="navigation" aria-label="Navigasi utama">
    <ul class="navbar-nav" role="list">
      <li class="nav-item" role="listitem">
        <!-- Fix: tambah aria-label pada link ikon tanpa teks -->
        <a class="nav-link" data-widget="pushmenu" href="#" role="button" aria-label="Toggle sidebar">
          <i class="fas fa-bars" aria-hidden="true"></i>
        </a>
      </li>
      <li class="nav-item d-none d-sm-inline-block" role="listitem">
        <a href="/dashboard" class="nav-link" aria-label="Beranda Konveksi App">
          <i class="fas fa-tshirt me-1" aria-hidden="true"></i>Konveksi App
        </a>
      </li>
    </ul>
    <ul class="navbar-nav ml-auto" role="list">
      <!-- Dark Mode Toggle -->
      <li class="nav-item" role="listitem">
        <a class="nav-link" href="#" id="navbar-theme-btn" onclick="toggleTheme(event)" title="Ganti Tema" aria-label="Ganti tema tampilan">
          <i class="fas fa-moon" id="theme-icon" aria-hidden="true"></i>
        </a>
      </li>
      <li class="nav-item dropdown" role="listitem">
        <a class="nav-link" data-toggle="dropdown" href="#" aria-label="Menu pengguna" aria-haspopup="true" aria-expanded="false">
          <i class="fas fa-user-circle me-1" aria-hidden="true"></i><%= user ? user.username : '' %>
          <span class="badge badge-<%= user && user.role==='admin' ? 'primary' : 'success' %> ml-1"><%= user ? user.role : '' %></span>
        </a>
        <div class="dropdown-menu dropdown-menu-right">
          <a href="/logout" class="dropdown-item text-danger">
            <i class="fas fa-sign-out-alt mr-2" aria-hidden="true"></i>Logout
          </a>
        </div>
      </li>
    </ul>
  </nav>

  <!-- Sidebar -->
  <aside class="main-sidebar sidebar-dark-primary elevation-4" aria-label="Sidebar navigasi">
    <a href="/dashboard" class="brand-link" aria-label="Dashboard Konveksi App">
      <i class="fas fa-tshirt brand-image ml-3" style="color:#fff;font-size:1.5rem" aria-hidden="true"></i>
      <span class="brand-text font-weight-bold ml-2">Konveksi App</span>
    </a>
    <div class="sidebar">
      <div class="user-panel mt-3 pb-3 mb-3 d-flex">
        <div class="image">
          <i class="fas fa-user-circle" style="font-size:2rem;color:#adb5bd;margin-left:8px" aria-hidden="true"></i>
        </div>
        <div class="info">
          <a href="#" class="d-block"><%= user ? user.username : '' %></a>
        </div>
      </div>
      <nav class="mt-2" aria-label="Menu sidebar">
        <!-- Fix: ganti role="menu" jadi role="list" agar li tidak perlu role menuitem -->
        <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="list">
          <li class="nav-item" role="listitem">
            <a href="/dashboard" class="nav-link <%= title==='Dashboard'?'active':'' %>" aria-label="Dashboard" <%= title==='Dashboard'?'aria-current="page"':'' %>>
              <i class="nav-icon fas fa-tachometer-alt" aria-hidden="true"></i>
              <p>Dashboard</p>
            </a>
          </li>
          <!-- Fix: nav-header pakai div bukan li agar tidak perlu parent ul/ol -->
          <li role="listitem"><div class="nav-header">MASTER DATA</div></li>
          <li class="nav-item" role="listitem">
            <a href="/karyawan" class="nav-link <%= title.includes('Karyawan')?'active':'' %>" aria-label="Data Karyawan" <%= title.includes('Karyawan')?'aria-current="page"':'' %>>
              <i class="nav-icon fas fa-users" aria-hidden="true"></i>
              <p>Data Karyawan</p>
            </a>
          </li>
          <li class="nav-item" role="listitem">
            <a href="/produk" class="nav-link <%= title.includes('Produk')?'active':'' %>" aria-label="Master Produk" <%= title.includes('Produk')?'aria-current="page"':'' %>>
              <i class="nav-icon fas fa-tshirt" aria-hidden="true"></i>
              <p>Master Produk</p>
            </a>
          </li>
          <li role="listitem"><div class="nav-header">OPERASIONAL</div></li>
          <li class="nav-item" role="listitem">
            <a href="/penggajian" class="nav-link <%= title.includes('Penggajian')?'active':'' %>" aria-label="Penggajian dan Produksi" <%= title.includes('Penggajian')?'aria-current="page"':'' %>>
              <i class="nav-icon fas fa-money-bill-wave" aria-hidden="true"></i>
              <p>Penggajian & Produksi</p>
            </a>
          </li>
          <li class="nav-item" role="listitem">
            <a href="/inventaris" class="nav-link <%= title.includes('Inventaris')?'active':'' %>" aria-label="Inventaris Produk Jadi" <%= title.includes('Inventaris')?'aria-current="page"':'' %>>
              <i class="nav-icon fas fa-boxes" aria-hidden="true"></i>
              <p>Inventaris Produk Jadi</p>
            </a>
          </li>
          <li role="listitem"><div class="nav-header">LAPORAN</div></li>
          <li class="nav-item" role="listitem">
            <a href="/laporan" class="nav-link <%= title.includes('Laporan')?'active':'' %>" aria-label="Laporan dan Grafik" <%= title.includes('Laporan')?'aria-current="page"':'' %>>
              <i class="nav-icon fas fa-chart-bar" aria-hidden="true"></i>
              <p>Laporan & Grafik</p>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </aside>

  <!-- Content Wrapper -->
  <div class="content-wrapper">
    <div class="content-header">
      <div class="container-fluid">
        <div class="row mb-2">
          <div class="col-sm-6">
            <h1 class="m-0"><%= title %></h1>
          </div>
        </div>
      </div>
    </div>
    <div class="content">
      <div class="container-fluid">

        <!-- Flash Messages -->
        <% if (success && success.length > 0) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2" aria-hidden="true"></i><%= success %>
            <button type="button" class="close" data-dismiss="alert" aria-label="Tutup"><span aria-hidden="true">&times;</span></button>
          </div>
        <% } %>
        <% if (error && error.length > 0) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2" aria-hidden="true"></i><%= error %>
            <button type="button" class="close" data-dismiss="alert" aria-label="Tutup"><span aria-hidden="true">&times;</span></button>
          </div>
        <% } %>
